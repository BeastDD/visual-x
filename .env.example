# NextAuth.js
NEXTAUTH_SECRET=your_super_secret_key_here_change_in_production
NEXTAUTH_URL=http://localhost:3000

# X / Twitter OAuth 2.0 (for next-auth TwitterProvider)
# Get these from https://developer.x.com/en/portal/dashboard (create a Project with OAuth 2.0 enabled)
AUTH_TWITTER_ID=your_client_id_here
AUTH_TWITTER_SECRET=your_client_secret_here

# X Bearer Token (for future API v2 video fetching)
X_BEARER_TOKEN=your_bearer_token_here

# Supabase (fill these in Sprint 1)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=